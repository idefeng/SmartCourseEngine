# SmartCourseEngine 环境配置示例
# 复制此文件为 .env 并修改配置

# ============================================================================
# 服务配置
# ============================================================================

# 服务名称
SERVICE_NAME=api-gateway
SERVICE_PORT=8000

# 调试模式
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# ============================================================================
# 数据库配置
# ============================================================================

# PostgreSQL
DATABASE_URL=postgresql://admin:admin123@localhost:5432/smartcourse

# Redis
REDIS_URL=redis://localhost:6379/0

# Neo4j
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=admin123

# Pinecone (向量数据库)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=smartcourse-knowledge

# ============================================================================
# 存储配置
# ============================================================================

# MinIO/S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123
MINIO_SECURE=false

# 存储桶
VIDEO_BUCKET=videos
DOCUMENT_BUCKET=documents
THUMBNAIL_BUCKET=thumbnails

# ============================================================================
# AI模型配置
# ============================================================================

# OpenAI/DeepSeek
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
EMBEDDING_MODEL=text-embedding-ada-002

# Whisper (语音识别)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu  # 或 cuda

# 视觉模型
CLIP_MODEL=openai/clip-vit-base-patch32
YOLO_MODEL=yolov8n.pt

# 本地LLM
LOCAL_LLM_ENABLED=false
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3

# ============================================================================
# 消息队列配置
# ============================================================================

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin123@localhost:5672

# 队列名称
VIDEO_ANALYSIS_QUEUE=video_analysis
KNOWLEDGE_EXTRACTION_QUEUE=knowledge_extraction
COURSE_GENERATION_QUEUE=course_generation
NOTIFICATION_QUEUE=notification

# ============================================================================
# 监控配置
# ============================================================================

PROMETHEUS_ENABLED=true
METRICS_PORT=9091

# 健康检查
HEALTH_CHECK_INTERVAL=30
READINESS_TIMEOUT=10
LIVENESS_TIMEOUT=30

# ============================================================================
# 安全配置
# ============================================================================

SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API密钥验证
API_KEY_HEADER=X-API-Key
REQUIRE_API_KEY=false

# ============================================================================
# 外部服务API密钥
# ============================================================================

# HeyGen (数字人视频)
HEYGEN_API_KEY=your-heygen-api-key-here

# 其他AI服务
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# ============================================================================
# 开发配置
# ============================================================================

# 配置文件路径
CONFIG_PATH=config.json

# 数据目录
DATA_DIR=./data
LOG_DIR=./logs
CACHE_DIR=./cache